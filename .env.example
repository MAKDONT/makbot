DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE
# Use VOICE_TARGETS for one service across multiple servers.
# Format: GUILD_ID:VOICE_CHANNEL_ID,GUILD_ID:VOICE_CHANNEL_ID
VOICE_TARGETS=YOUR_GUILD_ID_HERE:YOUR_VOICE_CHANNEL_ID_HERE

# Backward-compatible single target option (optional if VOICE_TARGETS is set):
GUILD_ID=YOUR_GUILD_ID_HERE
VOICE_CHANNEL_ID=YOUR_VOICE_CHANNEL_ID_HERE
RECONNECT_DELAY_MS=15000
HEALTHCHECK_INTERVAL_MS=60000
LOGIN_RETRY_DELAY_MS=20000